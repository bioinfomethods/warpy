
//-------------------------------------------
// Warpy bootstrap configuration for Bpipe
//
// - defines BASE variable for other configs to use
// - sets classpath for use within other configs
//-------------------------------------------

// Base is the parent directory of the src folder
BASE=new File(scriptPath).parentFile.parentFile.canonicalPath

parameters {
  setProperty('BASE',BASE)
  DORADO_VERSION="0.7.2"
}

environments {

    ont_server {
        libs=[
            "$BASE/classes",
            "$BASE/lib/groovy-ngs-utils.jar",

            // Because groovy-ngs-utils (via BioJava and HTSJDK) ships a conflicting slf4j we need
            // to add it again here to restore the compatible one
            // Without this, get classloader violation in agent hook replies
            "$BASE/tools/bpipe/0.9.14/lib/slf4j/slf4j-jdk14-1.7.25.jar"
        ]

        parameters {
            container_engine = "docker"
        }

        custom_storage_mounts = []
    }

 
    mac_dev {
        libs=[
            "$BASE/classes",
            "$BASE/lib/groovy-ngs-utils.jar",
        ]


        parameters {
            container_engine = "docker"
        }

        custom_storage_mounts = []
    }

    mcri_test {
        ARCHIE_HOME="/hpc/bpipeLibrary/shared/archie-test"

        parameters {
            setProperty('container_engine', 'singularity')
            setProperty('ARCHIE_HOME', ARCHIE_HOME)
        }

        libs=[
            "$BASE/classes",
            "$BASE/lib/groovy-ngs-utils.jar",
            "$ARCHIE_HOME/archie-common/build/libs/archie-common-all.jar"
        ]
    }

    mcri_prod {
        ARCHIE_HOME="/hpc/bpipeLibrary/shared/archie"

        parameters {
            setProperty('container_engine', 'singularity')
            setProperty('ARCHIE_HOME', ARCHIE_HOME)
        }

        libs=[
            "$BASE/classes",
            "$BASE/lib/groovy-ngs-utils.jar",
            "$ARCHIE_HOME/archie-common/build/libs/archie-common-all.jar"
        ]
    }
    
    mcri_dev {
        ARCHIE_HOME="/hpc/bpipeLibrary/shared/archie-test"

        parameters {
            setProperty('container_engine', 'singularity')
            setProperty('ARCHIE_HOME', ARCHIE_HOME)
        }

        libs=[
            "$BASE/classes",
            "$BASE/lib/groovy-ngs-utils.jar",
            "$ARCHIE_HOME/archie-common/build/libs/archie-common-all.jar"
        ]
    }

    vcgs_mk4 {
        libs=[
            "$BASE/classes",
            "$BASE/lib/groovy-ngs-utils.jar",

            // Because groovy-ngs-utils (via BioJava and HTSJDK) ships a conflicting slf4j we need
            // to add it again here to restore the compatible one
            // Without this, get classloader violation in agent hook replies
            "$BASE/tools/bpipe/0.9.14/lib/slf4j/slf4j-jdk14-1.7.25.jar"
        ]

        parameters {
            container_engine = "singularity"
        }

        custom_storage_mounts = []
    }


    vcgsdev {
        libs=[
            "$BASE/classes",
            "$BASE/lib/groovy-ngs-utils.jar",

            // Because groovy-ngs-utils (via BioJava and HTSJDK) ships a conflicting slf4j we need
            // to add it again here to restore the compatible one
            // Without this, get classloader violation in agent hook replies
            "$BASE/tools/bpipe/0.9.14/lib/slf4j/slf4j-jdk14-1.7.25.jar"
        ]

        parameters {
            container_engine = "docker"
        }

        custom_storage_mounts = []

        concurrency=4
    }
}
